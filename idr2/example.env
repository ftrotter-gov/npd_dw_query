# Snowflake IDR Parallel Export & Download Configuration
# Copy this file to .env and configure for your environment
# NOTE: .env should NOT be committed to git (contains local paths)

# Directory where downloaded CSV files will be stored
# This directory should already exist
DOWNLOAD_DIRECTORY=~/cms_data_downloads_possible_pii/idr_data/unmerged_csv_files

# Polling interval in minutes
# The downloader checks for new files and the exporter checks if folder is empty
# every this many minutes
POLLING_INTERVAL_MINUTES=5

# Stop polling after this many hours of no activity
# If no new files appear or folder doesn't empty after this duration, process stops
QUIT_AFTER_HOURS=2

# Snowflake connection configuration name (from ~/.snowsql/config)
SNOWFLAKE_CONFIG=cms_idr

# Path to snowsql executable (if not in standard location)
# Leave empty to use system PATH
SNOWSQL_PATH=/Applications/SnowSQL.app/Contents/MacOS/snowsql

# S3 bucket destination for merged CSV files
# Format: s3://your-bucket-name/optional/prefix/
# The aws CLI must be configured with credentials that can write to this bucket
S3_BUCKET=s3://your-bucket-name/idr_exports/
